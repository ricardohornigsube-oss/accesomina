# Use production only with HTTPS, S3 and malware scanning configured.
NODE_ENV=development
PORT=8088
APP_ORIGIN=http://localhost:8088
DATABASE_URL=postgres://accesomina:accesomina@localhost:5432/accesomina
SESSION_TTL_HOURS=8
REGISTRATION_INVITE_CODE=change-this-before-production-with-16-or-more-characters
TENANT_SECRET_KEY=replace-with-a-random-secret-of-at-least-32-characters
ADMIN_INITIAL_PASSWORD=ChangeThisAdminPassword1
COOKIE_SECURE=false

# Private files. Use S3 in production; local disk is only for development.
FILE_STORAGE=local
LOCAL_UPLOAD_DIR=./uploads
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
VIRUS_SCAN_API_URL=
VIRUS_SCAN_API_TOKEN=

# SMTP email integration
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Acceso Mina <no-reply@example.com>

# Meta WhatsApp Cloud API
WHATSAPP_GRAPH_VERSION=v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Optional integration webhooks
SIGNATURE_API_URL=
SIGNATURE_API_TOKEN=
ERP_WEBHOOK_URL=
ERP_WEBHOOK_TOKEN=
ACCREDITATION_WEBHOOK_URL=
ACCREDITATION_WEBHOOK_TOKEN=
